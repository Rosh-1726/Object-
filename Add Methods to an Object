const calculator = {
    add: function(a, b) { return a + b; },
    subtract: function(a, b) { return a - b; },
    multiply: function(a, b) { return a * b; },
    divide: function(a, b) { 
        return b !== 0 ? a / b : "Cannot divide by zero"; 
    }
};

// Example usage
console.log("Sum:", calculator.add(45, 45)); // Output: 90
console.log("Difference:", calculator.subtract(100, 50));
